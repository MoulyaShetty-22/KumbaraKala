<resources>
    <style name="Theme.KumbaraKala" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/terracotta_primary</item>
        <item name="colorPrimaryVariant">@color/terracotta_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/golden_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/cream_background</item>
        <item name="colorSurface">@color/cream_surface</item>
        <item name="android:windowBackground">@color/cream_background</item>
        <item name="colorOnBackground">@color/brown_text</item>
        <!-- Force black text everywhere -->
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/terracotta_primary</item>
        <item name="android:textColorHint">@color/hint_color</item>
        <item name="editTextColor">@color/black</item>
        <item name="android:editTextColor">@color/black</item>
        <!-- Input field colors -->
        <item name="colorControlActivated">@color/terracotta_primary</item>
        <item name="colorControlNormal">@color/terracotta_accent</item>
        <item name="colorControlHighlight">@color/golden_light</item>
        <!-- TextInputLayout -->
        <item name="textInputStyle">@style/KumbaraTextInput</item>
    </style>

    <style name="KumbaraTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/terracotta_primary</item>
        <item name="hintTextColor">@color/terracotta_primary</item>
        <item name="android:textColorHint">@color/hint_color</item>
        <item name="boxBackgroundColor">@color/cream_surface</item>
    </style>

    <style name="KumbaraEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/hint_color</item>
    </style>

    <style name="KumbaraToolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/terracotta_primary</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <style name="KumbaraButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/terracotta_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="KumbaraButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/terracotta_primary</item>
        <item name="android:textColor">@color/terracotta_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="KumbaraButtonGold" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/golden_accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="KumbaraFAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/terracotta_primary</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="SectionHeader">
        <item name="android:textColor">@color/terracotta_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
